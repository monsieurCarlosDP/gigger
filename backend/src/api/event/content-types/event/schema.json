{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Distance": {
      "type": "biginteger"
    },
    "Location": {
      "type": "string"
    },
    "Type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Reservation",
        "Event",
        "Viability"
      ]
    },
    "contacts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::person.person",
      "inversedBy": "events"
    },
    "Period": {
      "type": "boolean"
    },
    "StartDate": {
      "type": "date",
      "required": true
    },
    "EndDate": {
      "type": "date",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "Period"
            },
            true
          ]
        }
      }
    },
    "Budget": {
      "type": "component",
      "component": "event.budget",
      "repeatable": true
    },
    "Cancelled": {
      "type": "boolean"
    },
    "CancelledDate": {
      "type": "date"
    }
  }
}
