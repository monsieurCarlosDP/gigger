{
  "kind": "collectionType",
  "collectionName": "people",
  "info": {
    "singularName": "person",
    "pluralName": "people",
    "displayName": "Person"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "Email": {
      "type": "email"
    },
    "Number": {
      "type": "biginteger"
    },
    "Description": {
      "type": "richtext"
    },
    "Type": {
      "type": "enumeration",
      "enum": [
        "Client",
        "Provider",
        "Manager"
      ]
    },
    "events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event",
      "mappedBy": "contacts"
    }
  }
}
